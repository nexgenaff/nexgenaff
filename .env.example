# ──────────────────────────────────────────────
# Application
# ──────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ──────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────
# Prisma reads DATABASE_URL only. For Neon/Vercel deployments, make sure
# your deployment environment exposes the connection string under DATABASE_URL.
DATABASE_URL="postgresql://postgres:password@localhost:5432/nextgen_affiliates_pro"

# ──────────────────────────────────────────────
# Authentication - CHANGE IN PRODUCTION
# ──────────────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRY=86400

# ──────────────────────────────────────────────
# Admin User
# ──────────────────────────────────────────────
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="admin123"

# ──────────────────────────────────────────────
# IP2Location API
# ──────────────────────────────────────────────
IP2LOCATION_API_KEY="your-api-key-here"

# ──────────────────────────────────────────────
# CORS
# ──────────────────────────────────────────────
CORS_ALLOWED_ORIGINS="http://localhost:3000,https://*.vercel.app"

# ──────────────────────────────────────────────
# Vercel Domain API
# Required if your website should add the custom domain alias through the app
# instead of only through the Vercel dashboard.
# ──────────────────────────────────────────────
VERCEL_TOKEN="your-vercel-token"
VERCEL_PROJECT_ID="your-vercel-project-id"
VERCEL_PROJECT_NAME="your-vercel-project-name"
VERCEL_TEAM_ID="your-vercel-team-id-if-using-a-team"